# Copy this file to .env and fill in the keys you need.
# claw-tui loads .env automatically from the directory you run it from.

# ── Anthropic (Claude models) ─────────────────────────────────────────────
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...


# Optional: override the API base URL (e.g. for a proxy)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── OpenAI (GPT / o-series / Codex) ──────────────────────────────────────
# Get yours at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Optional: override the base URL (e.g. for Azure OpenAI or a local proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── xAI (Grok) ───────────────────────────────────────────────────────────
# Get yours at https://console.x.ai
# XAI_API_KEY=xai-...

# Optional: override the xAI base URL
# XAI_BASE_URL=https://api.x.ai/v1
